# ── Runtime data ──────────────────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
velox-master.pid
*.pid

# ── Production deployment artefacts (NEVER commit — see CHANGELOG) ──────────
# These wrap any depth to catch live operator inventories / env files that
# are generated next to test data or in sub-checkouts. Templates live under
# `*.example` (e.g. `deploy/inventory/production.ini.example`) and stay versioned.
**/production.ini
**/inventory.ini
**/inventory.yml
**/inventory.yaml
**/production.env
**/.env.production

# ── Cryptographic material (key/cert bundles, NEVER commit) ────────────────
# Covered globally so a stray key under any subdir is excluded.
*.key
*.pem
*.p12
*.pfx
*.csr
*.srl
# Test-data fixtures are an explicit re-include.
!**/testdata/**/*.pem
!**/testdata/**/*.key

# ── Operator credential store (master + ansible-vault tooling) ────────────
.velox-passwords.txt

# ── Secrets & credentials ──────────────────────────────────────────────────────────
refactored/DataServer/data/secrets/
refactored/DataServer/data/drive/credentials/
refactored/DataServer/data/drive/tokens/

# ── Runtime directories ──────────────────────────────────────────────────────
refactored/DataServer/data/analytics/
refactored/DataServer/data/backups/
refactored/DataServer/data/dark_editor/
refactored/DataServer/data/drive/
refactored/DataServer/data/jobs/
refactored/DataServer/data/youtube/
refactored/DataServer/data/worker_downloads/
refactored/DataServer/data/ansible/playbooks/inventory.ini
refactored/DataServer/completed_videos/

# ── Build artifacts ──────────────────────────────────────────────────────────
*.tsbuildinfo
*.tsbuildinfo.*
refactored/DataServer/bin/
refactored/DataServer/server
refactored/DataServer/velox-server
refactored/RemoteCodex/native/worker-agent-go/bin/
refactored/RemoteCodex/native/video-engine-cpp/build/

# ── Environment & IDE ────────────────────────────────────────────────────────
.env
.env.*
*.env
.velox/
.cline/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# ── Node ─────────────────────────────────────────────────────────────────────
node_modules/
refactored/frontend_standalone/web/node_modules/
refactored/frontend_standalone/web/test-results/
refactored/frontend_standalone/web/.svelte-kit/


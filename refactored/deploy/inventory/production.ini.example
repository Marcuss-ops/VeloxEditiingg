# Velox — production Ansible inventory (TEMPLATE).
# ────────────────────────────────────────────────────────────────────────────
# THIS FILE IS A TEMPLATE. Copy to a local `production.ini` and fill in real
# IPs/hostnames. The active inventory is generated and managed by the operator;
# it is NOT committed (recommend adding `deploy/inventory/production.ini`
# to .gitignore in your checkout).
#
# Bootstrapping a new node:
#   cp deploy/inventory/production.ini.example deploy/inventory/production.ini
#   $EDITOR deploy/inventory/production.ini   # fill in CHANGE_ME values
#
# Topologia (single-host for now):
#   * velox-master  — runs the master server (gRPC :9000 + REST :8000).
#   * velox-worker-1 — runs the worker agent. Co-located with the master for
#                       testing; in a true multi-host deployment, the worker
#                       lives on a separate physical machine and joins the
#                       worker's Tailscale mesh with the master.
#
# Previous multi-host template was REMOVED. The two unreachable nodes
# (local dev box and an offline Tailscale peer) are out of scope and would
# only add confusion. To scale up later, append new velox-worker-X entries
# under [velox_workers] and mirror them in deploy/group_vars/all.yml
# (velox_allowed_workers) + deploy/velox-server.env.example
# (VELOX_ALLOWED_WORKERS).
#
# Connection requirements:
#   * SSH key-based auth as user `velox-deploy` (created by bootstrap-ssh).
#   * sudo from `velox-deploy` to root (passwordless).
#   * Python 3 on the remote host.
#
# Hostgroups:
#   [velox_master]   — runs the master server. Single host.
#   [velox_workers]  — runs worker agents. One host per physical machine.
#
# Per-host vars:
#   worker_id        — stable identifier the master uses for gate/ACL.
#                      MUST match a value listed in `velox_allowed_workers`
#                      in deploy/group_vars/all.yml.

[velox_master]
velox-master ansible_host=CHANGE_ME ansible_user=velox-deploy

[velox_workers]
velox-worker-1 ansible_host=CHANGE_ME ansible_user=velox-deploy worker_id=velox-worker-1

[velox_master:vars]
ansible_python_interpreter=/usr/bin/python3

[velox_workers:vars]
ansible_python_interpreter=/usr/bin/python3

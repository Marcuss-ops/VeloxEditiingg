# Velox Server Environment — Canonical Template
# =============================================
# Source-of-truth template for the Velox master install.
#
# Usage:
#   1. Edit the values below (replace every CHANGE_ME).
#   2. Copy or symlink to /etc/velox-server.env.
#   3. Run:  sudo ./DataServer/data/deploy/install-server.sh
#
# The associated validator lives at deploy/validate-master-env.sh and is
# invoked by the installer (and by anyone running it directly) to check
# that this file is safe to use end-to-end.
#
# Variable names mirror what velox-server's config layer reads.
# Mandatory fields use the literal placeholder CHANGE_ME so the installer
# can refuse to start the service until the operator has filled them in.
#
# Production topology: the master serves exactly TWO externally-hosted
# workers (worker_1, worker_2). Each worker runs the systemd Go agent
# and authenticates against the master's VELOX_ALLOWED_WORKERS list.
# Real worker IDs are injected at deploy time via the ansible vault
# or /etc/velox-server.env — the versioned file below carries
# placeholders ONLY. Any commit that ships real worker IPs, IDs, or
# hostnames in this file MUST be reverted before merge.
# =============================================

# ── Server ─────────────────────────────────────────────────────────────────

# TCP port the master listens on (default: 8000).
VELOX_MASTER_PORT=8000

# Gin mode: release | debug | test.
GIN_MODE=release

# Public URL exposed to clients and worker agents.
# Workers use this to dial back into the master's gRPC control plane.
# The real DNS or public IP lives in /etc/velox-server.env (or the
# ansible vault) — never in the versioned template.
MASTER_PUBLIC_URL=http://CHANGE_ME_public_master_host:8000

# Code version, surfaced in logs and telemetry.
VELOX_CODE_VERSION=1.1.1

# ── gRPC Control Channel ───────────────────────────────────────────────────

# gRPC port for worker control streams. Set 0 or leave empty to disable gRPC
# (REST-only mode).
VELOX_GRPC_PORT=9000

# gRPC push mode. true => master pushes job offers to workers;
# false       => workers poll for jobs.
VELOX_GRPC_PUSH_MODE=true

# Optional TLS for gRPC (paths inside the per-host certificate bundle).
# VELOX_GRPC_TLS_CERT_FILE=/etc/velox/certs/server.crt
# VELOX_GRPC_TLS_KEY_FILE=/etc/velox/certs/server.key
# VELOX_GRPC_TLS_CA_FILE=/etc/velox/certs/ca.crt

# ── Storage paths ──────────────────────────────────────────────────────────

# Runtime root (parent of /data, /logs, /secrets, /videos).
VELOX_RUNTIME_DIR=/var/lib/velox

# SQLite database + artifact blob tree root.
VELOX_DATA_DIR=/var/lib/velox/data

# Database file (absolute path). THIS IS THE ONLY VELOX_DB_* KNOWN TO
# THE SERVER. The previous VELOX_DB_DSN alias has been retired: any
# legacy env file or Ansible var that still carries it is dropped on
# boot and produces no shadow state. See CHANGELOG.md (VeloxDB
# alias retirement) for the migration window.
VELOX_DB_PATH=/var/lib/velox/data/velox.db

# Rendered video output directory (used by worker-side scripts).
VELOX_VIDEOS_DIR=/var/lib/velox/videos

# Secrets root (TLS keys, OAuth credentials, vault refs).
VELOX_SECRETS_DIR=/etc/velox/secrets

# YouTube OAuth-specific paths under VELOX_SECRETS_DIR.
VELOX_YOUTUBE_TOKENS_DIR=/etc/velox/secrets/youtube/tokens
VELOX_YOUTUBE_CREDENTIALS_DIR=/etc/velox/secrets/youtube/credentials

# ── Security ───────────────────────────────────────────────────────────────

# Admin token for REST API. MANDATORY — the installer refuses to start the
# service while this contains the placeholder.
VELOX_ADMIN_TOKEN=CHANGE_ME_set_admin_token_here

# ── Worker Policy ──────────────────────────────────────────────────────────

# Comma-separated allowlist of worker IDs. This file is a TEMPLATE and
# carries ONLY placeholders. The canonical production rule is exactly
# TWO distinct worker IDs (see ValidateProductionWorkers in
# DataServer/internal/config/workers_validator.go). Real IDs are
# injected via the ansible vault or /etc/velox-server.env on the master.
#
# Mirror the allowlist in (operator responsibility — drift here = silent
# shadow outage on the next master restart):
#   - deploy/group_vars/all.yml       `velox_allowed_workers`
#   - deploy/inventory/production.ini `[velox_workers]` worker_id=
#   - deploy/runtime/worker.env.example on each worker (`VELOX_WORKER_ID`)
VELOX_ALLOWED_WORKERS=CHANGE_ME_WORKER_1,CHANGE_ME_WORKER_2

# Max retry attempts per job before moving to DLQ.
VELOX_MAX_JOB_ATTEMPTS=3

# Worker heartbeat timeout (seconds). Workers that miss two heartbeats are
# evicted and their leases reaped.
VELOX_WORKER_HEARTBEAT_TIMEOUT=120

# ── Remote Creator (optional) ──────────────────────────────────────────────

# VELOX_REMOTE_ENGINE_URL=
# VELOX_REMOTE_ENGINE_TOKEN=
# VELOX_REMOTE_ENGINE_TIMEOUT_MS=120000
# VELOX_REMOTE_ENGINE_RETRIES=1
# VELOX_REMOTE_ENGINE_POLL_INTERVAL=30

# ── YouTube (optional) ─────────────────────────────────────────────────────

# VELOX_YOUTUBE_CLIENT_ID=
# VELOX_YOUTUBE_CLIENT_SECRET=
# VELOX_YOUTUBE_REDIRECT_URL=

# ── TLS for REST API (optional) ────────────────────────────────────────────

# VELOX_TLS_CERT_FILE=/etc/velox/certs/rest-server.crt
# VELOX_TLS_KEY_FILE=/etc/velox/certs/rest-server.key

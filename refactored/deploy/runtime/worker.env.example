# Velox Worker — per-host environment template.
# ─────────────────────────────────────────────────────────────────────────────
# Copy to /etc/velox-worker/worker.env on the host and edit. Each OVH should
# have its own copy with values adjusted per host below.
#
# Variables here are read by both prepare-host.sh (image/version resolution)
# and the running worker container (env_file). Changes take effect on the
# next `docker compose up -d` for the host.

# ── Identity ───────────────────────────────────────────────────────────────
# Required: the worker_id MUST match the value declared on the
# [velox_workers] host in deploy/inventory/production.ini, and the matching
# entry in VELOX_ALLOWED_WORKERS in deploy/group_vars/all.yml.
VELOX_WORKER_ID=worker-ovh-1

# Friendly display name (logs, telemetry).
VELOX_WORKER_NAME=ovh-render-1

# ── Master connectivity ────────────────────────────────────────────────────
# Public host:port of the master's gRPC control plane.
# Use master.example.com:9000 in prod; localhost:9000 in dev.
VELOX_GRPC_MASTER_URL=master.example.com:9000

# ── Credential injection (read-only mounts at /run/velox/secrets) ─────────
# prepare-host.sh binds /etc/velox-worker/secrets → /run/velox/secrets (ro).
VELOX_WORKER_CREDENTIAL_FILE=/run/velox/secrets/worker_credential

# TLS for the gRPC link (cert files mounted from /etc/velox-worker/certs).
VELOX_GRPC_TLS_CERT_FILE=/run/velox/certs/worker.crt
VELOX_GRPC_TLS_KEY_FILE=/run/velox/certs/worker.key
VELOX_GRPC_TLS_CA_FILE=/run/velox/certs/ca.crt

# ── Workload configuration ─────────────────────────────────────────────────
# Work directory inside the container.
VELOX_WORK_DIR=/var/lib/velox-worker/work

# Maximum number of jobs this worker accepts in parallel.
VELOX_MAX_ACTIVE_JOBS=1

# Health endpoint port — must match the compose.yml healthcheck.
VELOX_HEALTH_PORT=8081

# ── Operationally-tunable extras (uncomment if needed) ────────────────────
# GIN_MODE=release
# LOG_LEVEL=info
# TZ=UTC

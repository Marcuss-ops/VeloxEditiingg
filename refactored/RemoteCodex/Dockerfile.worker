# ============================================================================
# Velox Worker - Multi-stage Build
# ============================================================================
# Stage 1: Build Go worker-agent binary
# No golang or source code in final image
# ============================================================================

# ── Build stage ──────────────────────────────────────────────────────────────
FROM golang:1.25-bookworm AS builder

WORKDIR /build

# Copy Go module files first for layer caching
COPY native/worker-agent-go/go.mod native/worker-agent-go/go.sum ./native/worker-agent-go/
RUN cd native/worker-agent-go && go mod download

# Copy worker-agent source
COPY native/worker-agent-go/ ./native/worker-agent-go/

# Build the binary
RUN cd native/worker-agent-go && \
    CGO_ENABLED=1 GOOS=linux go build -ldflags="-s -w" -o velox-worker-agent ./cmd/velox-worker-agent

# ── Runtime stage ────────────────────────────────────────────────────────────
FROM node:20-bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /app

# No golang-go in runtime image.
RUN apt-get update -qq && apt-get install -y --no-install-recommends \
    ffmpeg \
    curl \
    libnss3 \
    libnspr4 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    libpangocairo-1.0-0 \
    libgtk-3-0 \
    && rm -rf /var/lib/apt/lists/*

# Copy only the prebuilt binary from builder stage
COPY --from=builder /build/native/worker-agent-go/velox-worker-agent /usr/local/bin/velox-worker-agent

# Create non-root user for runtime
RUN useradd -r -m -s /usr/sbin/nologin velox

# Set permissions
RUN chown -R velox:velox /app /usr/local/bin/velox-worker-agent

USER velox

# ============================================================================
# ============================================================================
# The Go worker-agent-go is the DEFAULT runtime.
#
# Architecture (Nominal Path):
#   Go worker-agent-go (scheduler, master comms, retries)
#
# No Python. No Chrome/Headless. No Remotion.
# ============================================================================

# Health check via HTTP endpoint
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# Default: Go worker-agent-go
# The systemd unit or docker run command should specify the entrypoint.
# Example:
#   docker run velox-worker /usr/local/bin/velox-worker-agent --master http://master:8000
ENTRYPOINT ["/usr/local/bin/velox-worker-agent"]
CMD ["--master", "http://master:8000"]

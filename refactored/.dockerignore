# .dockerignore — scoped to DataServer/Dockerfile (context = project root).
# Reduce the BuildKit graph size and prevent accidental COPY of unrelated
# dirs (.git, node_modules, ansible inventories that may contain IPs,
# large test fixtures, etc.) into the image.
#
# Build paths we DO need:
#   shared/
#   DataServer/
# Anything below is excluded.

# VCS — never stage .git into a runtime image.
.git
.gitignore
.gitmodules

# Vendored module sources — kept in-tree but rebuilt by Go, not by Docker.
# (Drop this if a future PR switches from vendoring to a submodule —
# the builder will still need shared/ visible, but in that case
# `shared/` would be a submodule pointer and the source comes from the
# submodule checkout, not the working tree.)

# Local CI / hook tooling.
.mimocode/
.github/
.idea/
.vscode/
*.iml

# Python / Ansible / Jinja deliverables (large, contain secrets in
# production.ini). Always review before adding explicit allow rules.
deploy/
inventory/
ops/
ansible.cfg
playbooks/
group_vars/
runtime/
templates/

# Frontend SPA — built separately; not an input to the master image.
frontend_standalone/
web/src/
web/dist/
web/node_modules/
web/package-lock.json
web/.npmrc

# Native C++ / FFmpeg engine — built independently by the worker image,
# never copied from here.
RemoteCodex/native/video-engine-cpp/build*/
RemoteCodex/native/video-engine-cpp/cmake-build*/
RemoteCodex/native/video-engine-cpp/CMakeCache.txt
RemoteCodex/native/video-engine-cpp/CMakeFiles/
RemoteCodex/native/video-engine-cpp/*.o
RemoteCodex/native/video-engine-cpp/*.a

# Docs + ops scripts that shouldn't leak into runtime images.
docs/
CHANGELOG.md
README.md
LICENSE
scripts/
dod_check.sh
cleanup_finalize.sh
ci/

# Build artifacts that may exist locally.
RemoteCodex/native/worker-agent-go/bin/
RemoteCodex/native/worker-agent-go/build/
DataServer/bin/
DataServer/dist/
*.exe

# Logs / runtime data / SQLite databases that should NEVER be inside an
# image. Even if absent on a clean tree, declare them so a developer
# running the build inside a polluted workspace can't accidentally
# stage them.
*.log
*.db
*.db-journal
*.db-wal
*.db-shm
data/
tmp/
*.tmp# Tests / fixtures that should be brought in by `go test`, not Docker.
*_test.go
testdata/
__tests__/
fixtures/

# Belt-and-braces guard against the original P0 #1 incident: a path
# like `inventory/production.ini` (which previously leaked real Tailscale
# IPs into the git history) is already covered by the broad
# `inventory/` exclude above, but a contributor who later refactors
# the inventory layout could accidentally re-introduce the leak.
# This explicit guard catches any file named `production.ini`
# anywhere in the build context, regardless of which directory it
# lives in.
**/production.ini  

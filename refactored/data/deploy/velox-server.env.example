# ============================================================
# VELOX MASTER — Environment template
# Copy to /etc/velox-server.env and fill in real values.
# Keep a backup of the running env before every deploy.
# DO NOT commit /etc/velox-server.env — secrets belong in a vault.
# ============================================================

# ---------- Environment ----------
GIN_MODE=release
VELOX_CODE_VERSION=CHANGE_ME

# ---------- HTTP / gRPC ----------
VELOX_MASTER_PORT=8000
VELOX_STUDIO_PORT=5000

VELOX_GRPC_PORT=9000
VELOX_GRPC_PUSH_MODE=true

# Public URL advertised to workers for bundle download and API access.
# Use the Tailscale IP (100.x) or the public OVH hostname when workers
# are on the same tailnet / private network.
MASTER_PUBLIC_URL=http://CHANGE_ME:8000
VELOX_ALLOW_LOCALHOST_MASTER=false

# ---------- Runtime paths ----------
# Absolute paths required. The 'velox' system user must have rw access
# to data and videos; secrets may be read-only.
VELOX_RUNTIME_DIR=/var/lib/velox
VELOX_DATA_DIR=/var/lib/velox/data
VELOX_SECRETS_DIR=/etc/velox/secrets

VELOX_DB_PATH=/var/lib/velox/data/velox.db
VELOX_VIDEOS_DIR=/var/lib/velox/videos

# ---------- Authentication ----------
# Generate with: openssl rand -hex 32
VELOX_ADMIN_TOKEN=CHANGE_ME

# ---------- Worker management ----------
# Comma-separated list of worker IDs allowed to register.
# Leave empty to allow any worker (development only).
VELOX_ALLOWED_WORKERS=
VELOX_FORCE_SINGLE_WORKER=
VELOX_MAX_JOB_ATTEMPTS=3
VELOX_WORKER_HEARTBEAT_TIMEOUT=120
VELOX_WORKER_BUNDLE_DIR=/var/lib/velox/bundles

# ---------- Master TLS (optional) ----------
# Leave empty to run plain HTTP (development / internal network).
#VELOX_TLS_CERT_FILE=/etc/velox/secrets/http/server.crt
#VELOX_TLS_KEY_FILE=/etc/velox/secrets/http/server.key

# ---------- gRPC mTLS (optional) ----------
# Required when workers connect over the public internet.
# Leave empty to run plain gRPC (development / Tailscale).
#VELOX_GRPC_TLS_CERT_FILE=/etc/velox/secrets/grpc/server.crt
#VELOX_GRPC_TLS_KEY_FILE=/etc/velox/secrets/grpc/server.key
#VELOX_GRPC_TLS_CA_FILE=/etc/velox/secrets/grpc/ca.crt

# ---------- Frontend ----------
VELOX_SPA_DIR=
VELOX_GRADIO_APP_URL=http://127.0.0.1:7860
VELOX_DARK_EDITOR_DIR=
VELOX_DARK_EDITOR_PROXY_URL=

# ---------- Google Drive ----------
VELOX_DRIVE_CLIENT_ID=
VELOX_DRIVE_CLIENT_SECRET=
VELOX_DRIVE_REDIRECT_URI=
VELOX_DRIVE_TOKENS_DIR=/etc/velox/secrets/drive/tokens
VELOX_DRIVE_CREDENTIALS_DIR=/etc/velox/secrets/drive/credentials

# ---------- YouTube ----------
VELOX_YOUTUBE_API_KEY=
VELOX_YOUTUBE_TOKENS_DIR=/etc/velox/secrets/youtube/tokens
VELOX_YOUTUBE_CREDENTIALS_DIR=/etc/velox/secrets/youtube/credentials
VELOX_YOUTUBE_POSTING_PATH=/var/lib/velox/data/youtube/posting.json

# ---------- Object storage (optional) ----------
VELOX_S3_ENDPOINT=
VELOX_S3_REGION=eu-west-1
VELOX_S3_BUCKET=
VELOX_S3_ACCESS_KEY_ID=
VELOX_S3_SECRET_ACCESS_KEY=
VELOX_S3_USE_SSL=true

# ---------- NVIDIA AI (optional) ----------
VELOX_NVIDIA_API_KEY=
VELOX_NVIDIA_TEXT_URL=

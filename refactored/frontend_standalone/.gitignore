# Build artifacts of the standalone SvelteKit frontend.
# `dist/` is the build output of `npm run build`; the master server consumes
# it via VELOX_SPA_DIR. As of the velox-core split, this directory lives in
# its own repository and is no longer shipped alongside the Go backend.
web/dist/
web/.svelte-kit/
web/node_modules/
web/test-results/
web/build/


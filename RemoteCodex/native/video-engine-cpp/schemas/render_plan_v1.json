{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RenderPlanV1",
  "description": "Schema di definizione canonica per un video da renderizzare tramite Velox Video Engine C++",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "job_id": {
      "type": "string"
    },
    "canvas": {
      "type": "object",
      "properties": {
        "width": {
          "type": "integer",
          "default": 1920
        },
        "height": {
          "type": "integer",
          "default": 1080
        },
        "fps": {
          "type": "integer",
          "default": 30
        }
      },
      "required": ["width", "height", "fps"]
    },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["image", "video", "color"]
              },
              "url": {
                "type": "string"
              },
              "color_hex": {
                "type": "string"
              },
              "cache_key": {
                "type": "string"
              }
            },
            "required": ["type"]
          },
          "start_seconds": {
            "type": "number",
            "minimum": 0
          },
          "duration_seconds": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "transform": {
            "type": "object",
            "properties": {
              "scale_mode": {
                "type": "string",
                "enum": ["cover", "contain", "stretch"],
                "default": "cover"
              },
              "ken_burns_effect": {
                "type": "boolean",
                "default": false
              }
            }
          }
        },
        "required": ["source", "start_seconds", "duration_seconds"]
      }
    },
    "audio_tracks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source_url": {
            "type": "string"
          },
          "volume": {
            "type": "number",
            "minimum": 0,
            "maximum": 2,
            "default": 1.0
          },
          "start_time_offset": {
            "type": "number",
            "default": 0.0
          }
        },
        "required": ["source_url"]
      }
    },
    "output_path": {
      "type": "string"
    }
  },
  "required": ["version", "job_id", "canvas", "timeline", "audio_tracks", "output_path"]
}

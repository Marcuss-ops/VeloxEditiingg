  "description": "Top-N failure reasons per spec \u00a714 sibling family. Reason values are CLOSED-enum: worker.Code* constants only. Free-form reason strings leak cardinality; flag any drift as a regression.",
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "table",
      "title": "Failure reasons (top 10, 1h increase)",
      "description": "Top-N reasons driving FAILED attempts in the last hour. Scorecard v1 + spec \u00a714 sibling family velox_compute_failure_reasons_total.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "options": {
        "footer": { "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "1h increase", "desc": true }]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "topk(10, increase(velox_compute_failure_reasons_total[1h]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Failure reasons (rate, per reason)",
      "description": "Per-reason rate of failed compute attempts. The label `reason=` MUST stay a closed enum (worker.Code*).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "failures / sec",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (reason) (rate(velox_compute_failure_reasons_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    }
  ],

  "description": "Placement rejection distribution. The single-label counter family velox_placement_rejections_total{reason=...} records every matcher-side skip (handler_workers.go::recordPlacementRejections) and worker-side reject (handler_jobs.go::handleUnsupportedExecutorRejection). Reason values are a CLOSED enum of placement.RejectionCode values; cardinality stays bounded by the enum.",
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "timeseries",
      "title": "Placement rejections by reason (rate)",
      "description": "rate(velox_placement_rejections_total[5m]) grouped by reason label. Single-label counter family per spec §14 shape.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {

go 1.25.8

use (
	./DataServer
	./RemoteCodex/native/worker-agent-go
	./shared
)

// Canonical resolution for velox-shared inside the workspace.
// A `replace` declared here takes precedence over matching `replace`
// directives in member-module go.mod files (Go 1.21+ workspace resolution).
// DataServer and worker-agent-go keep their own in-tree `replace` clauses
// for non-workspace builds (CI runners / container entrypoints that enter
// a single sub-module without `go.work` on their lookup path).
replace velox-shared v0.0.0 => ./shared

use ./internal/application/images

use ./cmd/archcheck/scan

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RenderPlanV1",
  "description": "Schema di definizione canonica per un video da renderizzare tramite Velox Video Engine C++",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1,
          "default": 1920
        },
        "height": {
          "type": "integer",
          "minimum": 1,
          "default": 1080
        },
        "fps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120,
          "default": 30
        }
      },
      "required": ["width", "height", "fps"]
    },
    "timeline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "source": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "type": { "const": "image" },
                  "url": { "type": "string", "minLength": 1 },
                  "cache_key": { "type": "string" }
                },
                "required": ["type", "url"]
              },
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "type": { "const": "video" },
                  "url": { "type": "string", "minLength": 1 },
                  "cache_key": { "type": "string" }
                },
                "required": ["type", "url"]
              },
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "type": { "const": "color" },
                  "color_hex": { "type": "string", "minLength": 1 }
                },
                "required": ["type", "color_hex"]
              }
            ]
          },
          "duration_seconds": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "transform": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "scale_mode": {
                "type": "string",
                "enum": ["cover", "contain", "stretch"],
                "default": "cover"
              },
              "slow_zoom": {
                "type": "boolean",
                "default": true
              }
            }
          }
        },
        "required": ["source", "duration_seconds"]
      }
    },
    "audio_tracks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "source_url": {
            "type": "string",
            "minLength": 1
          },
          "volume": {
            "type": "number",
            "minimum": 0,
            "maximum": 2,
            "default": 1.0
          },
          "start_time_offset": {
            "type": "number",
            "minimum": 0,
            "default": 0.0
          }
        },
        "required": ["source_url"]
      }
    },
    "output_path": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["version", "job_id", "canvas", "timeline", "audio_tracks", "output_path"]
}

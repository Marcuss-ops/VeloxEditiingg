# =============================================================================
# Velox Master Environment — PR 3 E2E gRPC Control Plane Matrix
# =============================================================================
# Template for tests/e2e/grpc-control-plane/run.sh. The runner copies this
# template to <WORKDIR>/case-N/master.env and sed-patches the cases that
# need TLS or allowlist changes before each test.
#
# Connection from PR 1's migration recipe: server-side TLS triple maps directly
# to VELOX_GRPC_TLS_CERT_FILE / VELOX_GRPC_TLS_KEY_FILE / VELOX_GRPC_TLS_CA_FILE
# — the same contract documented in deploy/velox-server.env.example. Case 5
# and 6 deliberately unset all three to exercise the TLS-required + plaintext
# mismatch path; cases 2/3/4 set them; case 1 leaves them commented (no TLS).
#
# Operator-facing note: NEVER set VELOX_GRPC_ALLOW_INSECURE_DEV=true in production.
# The case-1 case uses it only because it is the LOCAL TEST MASTER; the
# production master must have neither TLS nor insecure dev bypass active.
# =============================================================================

# Listening ports (REST + gRPC control plane on localhost for the matrix).
VELOX_MASTER_PORT=8000
GIN_MODE=release
VELOX_GRPC_PORT=50051
VELOX_GRPC_PUSH_MODE=true

# Storage (use $WORKDIR per case so logs+db persist for post-mortem).
VELOX_RUNTIME_DIR=VELOX_RUNTIME_DIR_PLACEHOLDER
VELOX_DATA_DIR=VELOX_DATA_DIR_PLACEHOLDER
VELOX_DB_PATH=VELOX_DB_PATH_PLACEHOLDER
VELOX_VIDEOS_DIR=VELOX_VIDEOS_DIR_PLACEHOLDER

# Worker policy. run.sh patches this list per case so the registry
# assertion against GET /api/v1/workers lands only the workers we expect.
VELOX_ALLOWED_WORKERS=ALLOWED_WORKERS_PLACEHOLDER
VELOX_MAX_JOB_ATTEMPTS=3
VELOX_WORKER_HEARTBEAT_TIMEOUT=120

# Admin token for REST API lookups (assert.sh probes registry via /api/v1/workers).
VELOX_ADMIN_TOKEN=e2e-admin-token

# --- gRPC TLS (set per case by run.sh) ----------------------------------------
# CASE 1 (plaintext-only): all three lines commented — no TLS, rely on
#                          VELOX_GRPC_ALLOW_INSECURE_DEV=true.
# CASE 2 (TLS accept):     all three UNSET per cert dir.
# CASE 3 (bad-cert):       all three UNSET, but worker config points at an
#                          impostor leaf that won't chain to the CA.
# CASE 4 (wrong-CA):       server CA pool = CA-A; worker's leaf CA = CA-B.
# CASE 5 (plaintext vs TLS): same as case-2 triple UNSET + worker has no certs.
# CASE 6 (parallel 1+1 reject): case-2 triple UNSET + two workers (one valid, one bad).

# VELOX_GRPC_TLS_CERT_FILE=CERT_DIR_PLACEHOLDER/server.crt
# VELOX_GRPC_TLS_KEY_FILE=CERT_DIR_PLACEHOLDER/server.key
# VELOX_GRPC_TLS_CA_FILE=CERT_DIR_PLACEHOLDER/ca.crt

# Dev-bypass: ENABLE only for case 1. The default case (no TLS) is
# unsafe-by-default with PR 1; setting this flag is required for the
# dev-only plaintext case to be accepted.
# VELOX_GRPC_ALLOW_INSECURE_DEV=false

# Velox DataServer — environment variables
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to git!
#
# The master HTTP API must be reachable only from the InstaEdit BFF
# and internal services. Workers connect via the gRPC control plane.

# --- Social API (InstaEdit) ---
# Base URL of the InstaEdit Social API, e.g. https://api.instaedit.org.
# Velox posts artifact deliveries and callbacks to this host.
SOCIAL_API_URL=

# Server-to-server Bearer token shared with InstaEdit.
# MUST match InstaEdit's VELOX_API_TOKEN.
SOCIAL_API_TOKEN=

# Publicly reachable Velox URL used to build artifact download_url
# and callback_url passed to the Social API.
SOCIAL_CALLBACK_BASE_URL=

# --- InstaEdit control JWT ---
# Shared HS256 secret used to verify the short-lived JWT issued by
# the InstaEdit BFF when proxying user-facing requests to Velox.
# MUST be at least 32 bytes and identical to InstaEdit's VELOX_CONTROL_JWT_SECRET.
INSTAEDIT_CONTROL_JWT_SECRET=

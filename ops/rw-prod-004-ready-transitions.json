{
  "spec_ref": "RW-PROD-004 §6 / Evidence: 3 transition matrix + JSON",
  "transition_dimension": "state machine driven by (worker.go setConnState + MsgDrain handler) writes to telemetry.ReadySnapshot",
  "writer_set": [
    "worker.go setConnState(ConnReady) → telemetry.SetHealthRegistered(true) → telemetry.MarkRegistered(true)",
    "worker.go setConnState(ConnDisconnected) (3 sites: connect-fail, session-end, post-loop) → telemetry.SetHealthRegistered(false) → telemetry.MarkRegistered(false)",
    "worker.go receiveLoop MsgDrain → telemetry.MarkDrainMode(true)",
    "main.go composition root post-cache → telemetry.MarkCacheReady(true)",
    "main.go composition root post-blob → telemetry.MarkBlobReady(true)",
    "main.go composition root post-bootstrap.Ok() → telemetry.MarkBootstrapped(true)",
    "main.go composition root post-registry.MustRegister → telemetry.SetExecutorsCount(len)",
    "main.go composition root diskWatcher goroutine (15s tick) → telemetry.SetDiskState(freeBytes, thresholdBytes)"
  ],
  "reader_set": [
    "/health/live → never blocks on readiness (200 forever iff process goroutine alive)",
    "/health/ready → reads ReadySnapshot; 200 iff len(NotReadyReasons)==0",
    "/health (legacy) → X-Velox-Health-Deprecated header + body proxies /health/ready"
  ],
  "transitions": [
    {
      "label": "T1: process spawn → /health/ready returns 503 bootstrap_not_run",
      "trigger": "main() reaches logger.LogStartup before any ReadyState wiring",
      "snapshot": {
        "registered": false, "drain_mode": false, "bootstrapped": false,
        "executors_count": 0, "cache_ready": false, "blob_ready": false,
        "disk_free_bytes": 0, "disk_threshold_bytes": 0
      },
      "reasons": ["bootstrap_not_run", "not_registered", "executors.empty", "cache.not_initialized", "blob.not_initialized"],
      "http_status": 503
    },
    {
      "label": "T2: bootstrap.Ok() true → bootstrap_not_run drops",
      "trigger": "main.go MarkBootstrapped(true) after dispatchBootstrap returns nil",
      "snapshot": {
        "registered": false, "drain_mode": false, "bootstrapped": true,
        "executors_count": 1, "cache_ready": true, "blob_ready": true
      },
      "reasons": ["not_registered"],
      "http_status": 503,
      "note": "until transport hands the master the Hello+HelloAck round-trip"
    },
    {
      "label": "T3: HelloAck round-trip → /health/ready returns 200 OK",
      "trigger": "worker.go setConnState(ConnReady) → telemetry.SetHealthRegistered(true) → MarkRegistered(true)",
      "snapshot": {
        "registered": true, "drain_mode": false, "bootstrapped": true,
        "executors_count": 1, "cache_ready": true, "blob_ready": true,
        "disk_free_bytes": 1073741824, "disk_threshold_bytes": 268435456
      },
      "reasons": [],
      "http_status": 200
    },
    {
      "label": "T4: MsgDrain → /health/ready returns 503 drain_mode",
      "trigger": "worker.go receiveLoop MsgDrain → telemetry.MarkDrainMode(true)",
      "snapshot": {
        "registered": true, "drain_mode": true, "bootstrapped": true,
        "executors_count": 1, "cache_ready": true, "blob_ready": true,
        "disk_free_bytes": 1073741824, "disk_threshold_bytes": 268435456
      },
      "reasons": ["drain_mode"],
      "http_status": 503,
      "note": "live still 200 (process+liveness); ready 503 (not accepting new offers)"
    },
    {
      "label": "T5: disk watcher first sample below threshold → /health/ready returns 503 disk.critical",
      "trigger": "main.go diskWatcher goroutine ticks; telemetry.SetDiskState(50MiB, 256MiB)",
      "snapshot": {
        "registered": true, "drain_mode": false, "bootstrapped": true,
        "executors_count": 1, "cache_ready": true, "blob_ready": true,
        "disk_free_bytes": 52428800, "disk_threshold_bytes": 268435456
      },
      "reasons": ["disk.critical"],
      "http_status": 503
    },
    {
      "label": "T6: connect-fail → back off → /health/ready returns 503 not_registered (only)",
      "trigger": "worker.go setConnState(ConnDisconnected) (connect-fail branch) → telemetry.SetHealthRegistered(false)",
      "snapshot": {
        "registered": false, "drain_mode": false, "bootstrapped": true,
        "executors_count": 1, "cache_ready": true, "blob_ready": true
      },
      "reasons": ["not_registered"],
      "http_status": 503,
      "note": "after backoff sleep + successful Hello+HelloAck, T3 transitions back to 200"
    },
    {
      "label": "T7: SIGTERM → w.Stop() → all flags drop → process exits",
      "trigger": "worker.go Stop() → close(stopChan) + SetHealthRegistered(false) + MarkDrainMode(false)",
      "snapshot": {
        "registered": false, "drain_mode": false, "bootstrapped": true,
        "executors_count": 1, "cache_ready": true, "blob_ready": true
      },
      "reasons": ["not_registered"],
      "http_status": 503,
      "note": "process exits before next /health/ready probe; compose healthcheck moves state to unhealthy and restarts if restart=unless-stopped"
    }
  ],
  "test_assertion_corpus": [
    "internal/telemetry/ready_test.go :: TestReady_AllOK",
    "internal/telemetry/ready_test.go :: TestReady_BootstrapNotRun_OnFreshProcess",
    "internal/telemetry/ready_test.go :: TestReady_DrainMode",

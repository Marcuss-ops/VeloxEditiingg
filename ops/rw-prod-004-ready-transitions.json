    "internal/telemetry/health_test.go :: TestHealth_ReadyNoExecutors_NotReady",
    "internal/telemetry/health_test.go :: TestHealth_ReadyUnderDiskPressure_NotReady",
    "internal/telemetry/health_test.go :: TestHealth_LegacyAdapter_DeprecationHeader",
    "internal/telemetry/health_test.go :: TestHealth_LegacyAdapter_DowngradeToNotReady",
    "internal/telemetry/health_test.go :: TestHealth_ReadyMethodNotAllowed",
    "DataServer/internal/workers/registry_query_test.go :: TestRegistry_HasAtLeastOneLive_Empty",
    "DataServer/internal/workers/registry_query_test.go :: TestRegistry_HasAtLeastOneLive_OneLive",
    "DataServer/internal/workers/registry_query_test.go :: TestRegistry_HasAtLeastOneLive_AllStale",
    "DataServer/internal/workers/registry_query_test.go :: TestRegistry_HasAtLeastOneLive_Revoked",
    "DataServer/internal/workers/registry_query_test.go :: TestRegistry_HasAtLeastOneLive_StaleRejected_TwoLiveOk",

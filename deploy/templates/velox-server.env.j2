{# =============================================================
   Velox Server — master env, rendered from group_vars + vault.
   ---------------------------------------------------------------
   This template is the SINGLE source of truth for
   /etc/velox-server.env on the master. Edit deploy/group_vars/*
   (non-secret) and deploy/group_vars/vault.yml (secret), then
   re-run deploy/playbooks/deploy-master-config.yml to apply
   changes on the host.

   NEVER edit /etc/velox-server.env on the host directly — the
   next playbook run would silently overwrite the change.
   ============================================================= #}

# ── Server ─────────────────────────────────────────────────────────────────

VELOX_MASTER_PORT={{ velox_master_port }}
GIN_MODE=release
MASTER_PUBLIC_URL={{ velox_master_public_url }}
VELOX_CODE_VERSION={{ velox_version }}
VELOX_SERVER_IMAGE={{ velox_server_image }}

# ── gRPC Control Channel ───────────────────────────────────────────────────

VELOX_GRPC_PORT={{ velox_grpc_port }}
VELOX_GRPC_PUSH_MODE=true

# VELOX_GRPC_TLS_CERT_FILE=/etc/velox/certs/server.crt
# VELOX_GRPC_TLS_KEY_FILE=/etc/velox/certs/server.key
# VELOX_GRPC_TLS_CA_FILE=/etc/velox/certs/ca.crt

# ── Storage paths ──────────────────────────────────────────────────────────

VELOX_RUNTIME_DIR={{ velox_runtime_dir }}
VELOX_DATA_DIR={{ velox_data_dir }}
{# VELOX_DB_PATH is the single source of truth. The retired VELOX_DB_DSN
   alias is intentionally NOT rendered: legacy env files that still carry
   it are ignored on the next master restart (Config.Validate fails
   closed otherwise). See CHANGELOG (VeloxDB alias retirement). #}
VELOX_DB_PATH={{ velox_db_path }}
VELOX_VIDEOS_DIR={{ velox_videos_dir }}
VELOX_SECRETS_DIR={{ velox_secrets_dir }}

# ── Security ───────────────────────────────────────────────────────────────

VELOX_ADMIN_TOKEN={{ vault_velox_admin_token }}

# ── Worker Policy ──────────────────────────────────────────────────────────

VELOX_ALLOWED_WORKERS={{ velox_allowed_workers }}
VELOX_MAX_JOB_ATTEMPTS={{ velox_max_job_attempts }}
VELOX_WORKER_HEARTBEAT_TIMEOUT={{ velox_worker_heartbeat_timeout }}

# ── Remote Creator (optional, kept commented) ──────────────────────────────

# VELOX_REMOTE_ENGINE_URL=
# VELOX_REMOTE_ENGINE_TOKEN=
# VELOX_REMOTE_ENGINE_TIMEOUT_MS=120000
# VELOX_REMOTE_ENGINE_RETRIES=1
# VELOX_REMOTE_ENGINE_POLL_INTERVAL=30

# ── External Social API (delivery destination) ─────────────────────────────
# Velox publishes rendered artifacts to an external Social API that owns all
# social-platform concerns (OAuth, channels, tokens, quota, publishing
# state). Only the gateway endpoint and an API key live here; everything
# platform-specific is owned by the social repository and out of Velox's
# scope.
#
# Canonical env vars read by socialclient.ConfigFromEnv() on the Go side.
# Names match the keys in velox-server/internal/socialclient/config.go EXACTLY:
# `SOCIAL_API_TIMEOUT_MS` (NOT `_MS`-less) — the literal key read by the client.
SOCIAL_API_URL={{ velox_social_api_url }}
SOCIAL_API_TOKEN={{ vault_velox_social_api_token | default("") }}
SOCIAL_API_TIMEOUT_MS={{ velox_social_api_timeout_ms }}
SOCIAL_API_RETRIES={{ velox_social_api_retries }}
SOCIAL_CALLBACK_BASE_URL={{ velox_social_callback_base_url }}
{# Future-proof placeholders consumed by the social_repo contract roadmap.
   They render as blank unless overridden in group_vars/all.yml or vault:
   SOCIAL_ARTIFACT_PUBLIC_URL (non-secret, from all.yml)
   SOCIAL_WEBHOOK_SECRET    (secret,    from vault.yml) #}
SOCIAL_ARTIFACT_PUBLIC_URL={{ velox_social_artifact_public_url }}
SOCIAL_WEBHOOK_SECRET={{ vault_velox_social_webhook_secret | default("") }}
{# Legacy `SOCIAL_GATEWAY_*` aliases — accepted today by socialclient.
   URL/Callback are non-secret (from all.yml); the API key is secret (vault). #}
SOCIAL_GATEWAY_URL={{ velox_social_gateway_url | default("") }}
SOCIAL_GATEWAY_API_KEY={{ vault_velox_social_gateway_api_key | default("") }}
SOCIAL_GATEWAY_CALLBACK_BASE_URL={{ velox_social_gateway_callback_base_url | default("") }}

# ── TLS for REST API (optional, kept commented) ────────────────────────────

# VELOX_TLS_CERT_FILE=/etc/velox/certs/rest-server.crt
# VELOX_TLS_KEY_FILE=/etc/velox/certs/rest-server.key

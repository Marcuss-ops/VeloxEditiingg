# Velox Server Environment — Canonical Template
# =============================================
# Source-of-truth template for the Velox master install.
#
# Usage:
#   1. Edit the values below (replace every CHANGE_ME).
#   2. Copy or symlink to /etc/velox-server.env.
#   3. Run:  sudo ./DataServer/data/deploy/install-server.sh
#
# The associated validator lives at deploy/validate-master-env.sh and is
# invoked by the installer (and by anyone running it directly) to check
# that this file is safe to use end-to-end.
#
# Variable names mirror what velox-server's config layer reads.
# Mandatory fields use the literal placeholder CHANGE_ME so the installer
# can refuse to start the service until the operator has filled them in.
#
# Production topology: the master serves any N >= 1 externally-hosted
# workers (the fleet size is not bounded — operators may scale up or
# down freely). Each worker runs the systemd Go agent and authenticates
# against the master's VELOX_ALLOWED_WORKERS list.
# Real worker IDs are injected at deploy time via the ansible vault
# or /etc/velox-server.env — the versioned file below carries
# placeholders ONLY. Any commit that ships real worker IPs, IDs, or
# hostnames in this file MUST be reverted before merge.
# =============================================

# ── Server ─────────────────────────────────────────────────────────────────

# TCP port the master listens on (default: 8000).
VELOX_MASTER_PORT=8000

# Gin mode: release | debug | test.
GIN_MODE=release

# Public URL exposed to clients and worker agents.
# Workers use this to dial back into the master's gRPC control plane.
# The real DNS or public IP lives in /etc/velox-server.env (or the
# ansible vault) — never in the versioned template.
MASTER_PUBLIC_URL=https://CHANGE_ME_MASTER_HOST

# Code version, surfaced in logs and telemetry.
VELOX_CODE_VERSION=1.2.0

# Immutable server image reference. Pin to a GHCR digest produced by
# .github/workflows/master-image.yml, never to a mutable tag.
VELOX_SERVER_IMAGE=ghcr.io/CHANGE_ME_OWNER/velox-server@sha256:CHANGE_ME_SERVER_IMAGE_DIGEST

# ── gRPC Control Channel ───────────────────────────────────────────────────

# gRPC port for worker control streams. Set 0 or leave empty to disable gRPC
# (REST-only mode).
VELOX_GRPC_PORT=9000

# gRPC push mode. true => master pushes job offers to workers;
# false       => workers poll for jobs.
VELOX_GRPC_PUSH_MODE=true

# Optional TLS for gRPC (paths inside the per-host certificate bundle).
# VELOX_GRPC_TLS_CERT_FILE=/etc/velox/certs/server.crt
# VELOX_GRPC_TLS_KEY_FILE=/etc/velox/certs/server.key
# VELOX_GRPC_TLS_CA_FILE=/etc/velox/certs/ca.crt

# ── Storage paths ──────────────────────────────────────────────────────────

# Runtime root (parent of /data, /logs, /secrets, /videos).
VELOX_RUNTIME_DIR=/var/lib/velox

# SQLite database + artifact blob tree root.
VELOX_DATA_DIR=/var/lib/velox/data

# Database file (absolute path). THIS IS THE ONLY VELOX_DB_* KNOWN TO
# THE SERVER. The previous VELOX_DB_DSN alias has been retired: any
# legacy env file or Ansible var that still carries it is dropped on
# boot and produces no shadow state. See CHANGELOG.md (VeloxDB
# alias retirement) for the migration window.
VELOX_DB_PATH=/var/lib/velox/data/velox.db

# Rendered video output directory (used by worker-side scripts).
VELOX_VIDEOS_DIR=/var/lib/velox/videos

# Secrets root (TLS keys, OAuth credentials, vault refs).
VELOX_SECRETS_DIR=/etc/velox/secrets

# ── Security ───────────────────────────────────────────────────────────────

# Admin token for REST API. MANDATORY — the installer refuses to start the
# service while this contains the placeholder.
VELOX_ADMIN_TOKEN=CHANGE_ME_set_admin_token_here

# ── Worker Policy ──────────────────────────────────────────────────────────

# Comma-separated allowlist of worker IDs. This file is a TEMPLATE and
# carries ONLY placeholders. The canonical production rule is any N >= 1
# distinct, non-wildcard, unique worker IDs (see ValidateProductionWorkers
# in DataServer/internal/config/workers_validator.go). Real IDs are
# injected via the ansible vault or /etc/velox-server.env on the master.
#
# Mirror the allowlist in (operator responsibility — drift here = silent
# shadow outage on the next master restart):
#   - deploy/group_vars/all.yml       `velox_allowed_workers`
#   - deploy/inventory/production.ini `[velox_workers]` worker_id=
#   - deploy/runtime/worker.env.example on each worker (`VELOX_WORKER_ID`)
VELOX_ALLOWED_WORKERS=CHANGE_ME_ALLOWED_WORKERS

# Max retry attempts per job before moving to DLQ.
VELOX_MAX_JOB_ATTEMPTS=3

# Worker heartbeat timeout (seconds). Workers that miss two heartbeats are
# evicted and their leases reaped.
VELOX_WORKER_HEARTBEAT_TIMEOUT=120

# ── Remote Creator (optional) ──────────────────────────────────────────────

# VELOX_REMOTE_ENGINE_URL=
# VELOX_REMOTE_ENGINE_TOKEN=
# VELOX_REMOTE_ENGINE_TIMEOUT_MS=120000
# VELOX_REMOTE_ENGINE_RETRIES=1
# VELOX_REMOTE_ENGINE_POLL_INTERVAL=30

# ── External Social API (delivery destination) ──────────────────────────────
# Velox publishes rendered artifacts to an external Social API that owns all
# social-platform concerns (OAuth, channels, tokens, quota, publishing
# state). Only the gateway endpoint and an API key live here; everything
# platform-specific (including any YouTube wiring) is owned by the social
# repository and out of Velox's scope.
#
# VELOX_SOCIAL_API_URL=
# VELOX_SOCIAL_API_TOKEN=
# VELOX_SOCIAL_API_TIMEOUT_MS=30000
# VELOX_SOCIAL_API_RETRIES=3
# VELOX_SOCIAL_CALLBACK_BASE_URL=

# ── TLS for REST API (optional) ────────────────────────────────────────────

# VELOX_TLS_CERT_FILE=/etc/velox/certs/rest-server.crt
# VELOX_TLS_KEY_FILE=/etc/velox/certs/rest-server.key

# ── Invariants / Tripwires (RW-PROD-008 A4) ────────────────────────────────

# When set, the master runs a pre-commit ffprobe audio-stream-count
# invariant on every verified-finalization tx (Service.Finalize),
# tripping ErrFFProbeAudioCountMismatch when the artifact's audio
# stream count ≠ the per-job delivery plan's destination count.
# Catches the canonical C++-engine amix-collapse regression (a
# 6-voice payload silently landing as 1-track READY).
#
# Tri-state semantics (mirror parseFFProbeMode() in
# DataServer/internal/artifacts/service_finalize_ffprobe.go EXACTLY;
# a typo disables the gate visibly rather than silently):
#
#   shadow    — run ffprobe + log every outcome + return nil to the
#               orchestrator. PRODUCTION-SAFE in Stage 1 (24h
#               observation window — see docs/rw-prod/RW-PROD-008-A4-
#               shadow-rollout.md). The default mode we roll first.
#
#   enforce   — run ffprobe + log + ABORT the finalize tx on a
#               trip (ErrFFProbeAudioCountMismatch when counts
#               differ, ErrFFProbeInvariantMissingBinary when
#               ffprobe is absent from PATH). Stage 2 promotes
#               the master here after Stage 1 confirms the gate's
#               calibration on real traffic.
#
#   true      — legacy alias for `enforce`. Any env file shipped
#               before the tri-state intro keeps its hard-trip
#               behavior; the install-server.sh preflight accepts
#               it 1:1 with `enforce`.
#
# Anything else (unset, `off`, `1`, `TRUE`, `yes`, missing key,
# typos like `True` / `Enable` / `shadow ` with a trailing space)
# is a NO-OP. Strict case-sensitive match — the runbook's grep on
# `[TRIPWIRE]` in journalctl never tires on a typo.
#
# Operator preflight: deploy/install-server.sh runs a
# `preflight_ffprobe_invariant` step that hard-fails the install
# when this flag is set to ANY active mode (shadow / enforce /
# true) but the `ffprobe` binary is missing from the master's
# PATH. Run `apt-get install -y ffmpeg` (or distro-equivalent)
# on the master host BEFORE uncommenting any active mode.
# Covered by the runbook at
#   docs/rw-prod/RW-PROD-008-A4-shadow-rollout.md.
#
# Cluster-wide rollout (per RW-PROD-008 A4 scope):
#   Stage 1 (now)   : master alone, shadow mode (this file uncommented
#                     with =shadow below).
#   Stage 2 (later) : same master, flip to =enforce after 24h clean
#                     signal. Worker port deferred to a future
#                     incarnation (no worker-side config tonight).
#
# Currently uncommented to enable Stage 1 shadow.
# VELOX_FFPROBE_VERIFY_ON_FINALIZE=shadow

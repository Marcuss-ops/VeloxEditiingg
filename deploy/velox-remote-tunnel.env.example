# Copy to ~/.config/velox/remote-tunnel.env and chmod 600.
# SSH key/agent authentication is required; never add a password here.
VELOX_REMOTE_SSH_HOST=CHANGE_ME
VELOX_REMOTE_SSH_USER=CHANGE_ME
VELOX_REMOTE_SSH_PORT=22

# Local loopback endpoints used by operator commands.
VELOX_TUNNEL_MASTER_PORT=18080
VELOX_TUNNEL_CREATOR_PORT=18000
VELOX_TUNNEL_GRPC_PORT=18505

# Remote loopback endpoints. These match the current pilot topology.
VELOX_REMOTE_MASTER_PORT=8080
VELOX_REMOTE_CREATOR_PORT=8000
VELOX_REMOTE_GRPC_PORT=50051
